{
    "document": {
        "block_prefix": "\n",
        "block_suffix": "\n",
        "color": "7",
        "margin": 2
    },
    "block_quote": {
        "indent": 1,
        "indent_token": "| ",
        "italic": true
    },
    "paragraph": {},
    "list": {
        "level_indent": 2
    },
    "heading": {
        "block_suffix": "\n",
        "bold": true
    },
    "h1": {
        "prefix": " ",
        "suffix": " ",
        "bold": true,
        "background_color": "8",
        "color": "5"
    },
    "h2": {
        "prefix": "## ",
        "color": "4",
        "bold": true
    },
    "h3": {
        "prefix": "### ",
        "color": "6"
    },
    "h4": {
        "prefix": "#### ",
        "color": "6"
    },
    "h5": {
        "prefix": "##### ",
        "color": "2"
    },
    "h6": {
        "prefix": "###### ",
        "color": "3"
    },
    "text": {},
    "strikethrough": {
        "crossed_out": true
    },
    "emph": {
        "italic": true
    },
    "strong": {
        "bold": true,
        "color": "5"
    },
    "hr": {
        "color": "7",
        "format": "\n────────────────────────────────────────────────────────────────────────────\n"
    },
    "item": {
        "block_prefix": "* "
    },
    "enumeration": {
        "block_prefix": ". "
    },
    "task": {
        "ticked": "[x] ",
        "unticked": "[ ] "
    },
    "link": {
        "color": "4",
        "underline": true
    },
    "link_text": {
        "color": "6",
        "bold": true
    },
    "image_text": {},
    "code": {
        "prefix": " ",
        "suffix": " ",
        "color": "2",
        "background_color": "8"
    },
    "code_block": {
        "indent": 1,
        "margin": 2,
        "chroma": {
            "text": {
                "color": "%C7%"
            },
            "error": {
                "color": "%C9%"
            },
            "comment": {
                "italic": true
            },
            "comment_multiline": {
                "italic": true
            },
            "comment_preproc": {
                "color": "%C6%"
            },
            "comment_preprocfile": {
                "color": "%C6%"
            },
            "comment_single": {
                "italic": true
            },
            "comment_special": {
                "color": "%C5%",
                "italic": true
            },
            "generic_deleted": {
                "color": "%C1%"
            },
            "generic_emph": {
                "italic": true
            },
            "generic_error": {
                "color": "%C1%"
            },
            "generic_heading": {
                "bold": true,
                "color": "%C5%"
            },
            "generic_inserted": {
                "color": "%C2%"
            },
            "generic_output": {
                "color": "%C7%"
            },
            "generic_prompt": {
                "bold": true,
                "color": "%C4%"
            },
            "generic_strong": {
                "bold": true
            },
            "generic_subheading": {
                "bold": true,
                "color": "%C4%"
            },
            "generic_traceback": {
                "color": "%C1%"
            },
            "keyword": {
                "color": "%C5%"
            },
            "keyword_constant": {
                "color": "%C3%"
            },
            "keyword_declaration": {
                "color": "%C4%"
            },
            "keyword_namespace": {
                "color": "%C6%"
            },
            "keyword_pseudo": {
                "color": "%C5%"
            },
            "keyword_reserved": {
                "color": "%C5%"
            },
            "keyword_type": {
                "color": "%C3%"
            },
            "literal_number": {
                "color": "%C3%"
            },
            "literal_number_bin": {
                "color": "%C3%"
            },
            "literal_number_float": {
                "color": "%C3%"
            },
            "literal_number_hex": {
                "color": "%C3%"
            },
            "literal_number_integer": {
                "color": "%C3%"
            },
            "literal_number_integer_long": {
                "color": "%C3%"
            },
            "literal_number_oct": {
                "color": "%C3%"
            },
            "literal_string": {
                "color": "%C2%"
            },
            "literal_string_affix": {
                "color": "%C2%"
            },
            "literal_string_back_tick": {
                "color": "%C2%"
            },
            "literal_string_char": {
                "color": "%C3%"
            },
            "literal_string_delimiter": {
                "color": "%C2%"
            },
            "literal_string_doc": {
                "color": "%C7%",
                "italic": true
            },
            "literal_string_double": {
                "color": "%C2%"
            },
            "literal_string_escape": {
                "color": "%C5%"
            },
            "literal_string_heredoc": {
                "color": "%C2%"
            },
            "literal_string_interpol": {
                "color": "%C6%"
            },
            "literal_string_other": {
                "color": "%C2%"
            },
            "literal_string_regex": {
                "color": "%C6%"
            },
            "literal_string_single": {
                "color": "%C2%"
            },
            "literal_string_symbol": {
                "color": "%C1%"
            },
            "name_attribute": {
                "color": "%C4%"
            },
            "name_builtin": {
                "color": "%C3%"
            },
            "name_builtin_pseudo": {
                "color": "%C3%"
            },
            "name_class": {
                "color": "%C3%"
            },
            "name_constant": {
                "color": "%C3%"
            },
            "name_decorator": {
                "color": "%C6%"
            },
            "name_entity": {
                "color": "%C3%"
            },
            "name_exception": {
                "color": "%C1%"
            },
            "name_function": {
                "color": "%C4%"
            },
            "name_function_magic": {
                "color": "%C6%"
            },
            "name_label": {
                "color": "%C4%"
            },
            "name_namespace": {
                "color": "%C3%"
            },
            "name_tag": {
                "color": "%C5%"
            },
            "name_variable": {
                "color": "%C1%"
            },
            "name_variable_class": {
                "color": "%C3%"
            },
            "name_variable_global": {
                "color": "%C1%"
            },
            "name_variable_instance": {
                "color": "%C1%"
            },
            "name_variable_magic": {
                "color": "%C6%"
            },
            "operator": {
                "color": "%C6%"
            },
            "operator_word": {
                "color": "%C5%"
            },
            "punctuation": {
                "color": "%C7%"
            }
        }
    },
    "table": {
        "center_separator": "+",
        "column_separator": "|",
        "row_separator": "-"
    },
    "definition_list": {},
    "definition_term": {},
    "definition_description": {
        "block_prefix": "\n> "
    },
    "html_block": {},
    "html_span": {}
}
